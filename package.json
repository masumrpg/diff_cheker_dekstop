{
	"name": "diff-checker-desktop",
	"version": "1.0.0",
	"description": "Desktop diff checker application - Compare text files with ease",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"@monaco-editor/react": "^4.7.0",
		"diff": "^8.0.4",
		"electrobun": "1.16.0",
		"highlight.js": "^11.11.1",
		"lucide-react": "^1.7.0",
		"monaco-editor": "^0.55.1",
		"react": "^18.3.1",
		"react-diff-viewer-continued": "^4.2.0",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/highlight.js": "^10.1.0",
		"@types/node": "^25.5.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
